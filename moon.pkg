import {
  "lepus-apps/lepus",
  "lepus-apps/webview",
}

supported_targets = "+native"

options(
  "is-main": true,
  link: {
    "native": {
      "cc": ".mooncakes/lepus-apps/lepus/_build/native/release/build/cli/cc/cc.exe",
    },
  },
  targets: { "env.debug.mbt": [ "debug" ], "env.release.mbt": [ "release" ] },
)
