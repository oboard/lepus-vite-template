{
  "name": "lepus-vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "cd .mooncakes/lepus-apps/lepus/ && moon build cli/cc --release",
    "start": "vite",
    "preview": "vite preview",
    "build": "tsc && vite build",
    "dev": "cross-env LEPUS_DEV_URL=http://localhost:2333 concurrently -k \"vite dev --port 2333\" \"moon run main.mbt\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "cross-env": "^10.1.0"
  }
}
