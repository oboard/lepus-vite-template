{
  "name": "lepus-vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "moon check && cd .mooncakes/lepus-apps/lepus/ && moon build cli/cc --release",
    "start": "vite",
    "preview": "vite preview",
    "build": "tsc && vite build && moon build --release",
    "dev": "concurrently -k \"vite dev --port 2333\" \"moon run main.mbt\""
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}